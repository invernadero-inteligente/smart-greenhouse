# ============================================================================
# .env.example - Plantilla de Variables de Entorno (sin valores sensibles)
# ============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo como ".env"
# 2. Completa los valores con tu configuración local/producción
# 3. NO incluyas .env en git (ya está en .gitignore)
# ============================================================================

# SERVER
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/
SERVER_SERVLET_SESSION_TIMEOUT=3600

# DATABASE - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=invernadero_db
DB_USERNAME=postgres
DB_PASSWORD=CAMBIAR_POR_CONTRASEÑA_REAL
DB_DRIVER_CLASS_NAME=org.postgresql.Driver

# Hibernate / JPA
JPA_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
JPA_PROPERTIES_HIBERNATE_USE_SQL_COMMENTS=true

# LOGGING
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_INVERNADERO=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_PATTERN_CONSOLE=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
LOGGING_PATTERN_FILE=%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n

# JWT - CAMBIAR_POR_CLAVE_SEGURA_EN_PRODUCCIÓN
JWT_SECRET=CAMBIAR_POR_CLAVE_SECRETA_DE_MINIMO_32_CARACTERES
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# APPLICATION
APP_NAME=Invernadero Inteligente Backend
APP_VERSION=1.0.0
APP_DESCRIPTION=Sistema de Gestión de Invernadero Inteligente
APP_ENVIRONMENT=development

# MAIL - Configurar con credenciales reales
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CAMBIAR_POR_EMAIL_REAL
MAIL_PASSWORD=CAMBIAR_POR_CONTRASEÑA_APLICACION
MAIL_FROM=noreply@invernadero.com
MAIL_PROTOCOL=smtp
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_DEBUG=false

# IoT - MQTT
IOT_MQTT_BROKER_URL=mqtt://localhost:1883
IOT_MQTT_CLIENT_ID=invernadero-backend
IOT_MQTT_USERNAME=mqtt_user
IOT_MQTT_PASSWORD=CAMBIAR_POR_CONTRASEÑA_MQTT
IOT_MQTT_TOPIC_PREFIX=invernadero/

# ACTUALIZACIONES
UPDATE_CHECK_ENABLED=true
MAINTENANCE_MODE=false

